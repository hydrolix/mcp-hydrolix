{
  "manifest_version": "0.4",
  "name": "${DIST_NAME}",
  "display_name": "${DISPLAY_NAME}",
  "version": "${VERSION}",
  "description": "${DESCRIPTION}",
  "long_description": "${LONG_DESCRIPTION}",
  "author": { "name": "${AUTHOR_NAME}", "url": "${AUTHOR_URL}" },
  "license": "Apache-2.0",
  "homepage": "${HOMEPAGE}",
  "repository": { "type": "git", "url": "${REPOSITORY}" },
  "icon": "icon.png",
  "keywords": ${KEYWORDS},
  "server": {
    "type": "uv",
    "entry_point": "src/server.py",
    "mcp_config": {
      "command": "uv",
      "args": ["run", "--directory", "${__dirname}", "src/server.py"],
      "env": {
        "${ENV_PREFIX}URL": "${user_config.${CFG_PREFIX}url}",
        "${ENV_PREFIX}TOKEN": "${user_config.${CFG_PREFIX}token}",
        "${ENV_PREFIX}USER": "${user_config.${CFG_PREFIX}user}",
        "${ENV_PREFIX}PASSWORD": "${user_config.${CFG_PREFIX}password}",
        "${ENV_PREFIX}MCP_SERVER_TRANSPORT": "stdio"
      }
    }
  },
  "tools": [
    { "name": "run_select_query", "description": "Execute a SELECT SQL query on the configured ${BRAND_NAME} cluster." },
    { "name": "list_databases",   "description": "List all databases on the ${BRAND_NAME} cluster." },
    { "name": "list_tables",      "description": "List all tables in a given database." },
    { "name": "get_table_info",   "description": "Return schema and metadata for a table." }
  ],
  "tools_generated": false,
  "user_config": {
    "${CFG_PREFIX}url": {
      "type": "string",
      "title": "${DISPLAY_NAME} URL",
      "description": "Canonical URL of your ${BRAND_NAME} cluster (e.g. ${EXAMPLE_URL}).",
      "required": true
    },
    "${CFG_PREFIX}token": {
      "type": "string",
      "title": "Service Account Token",
      "description": "Service-account token. Preferred over username/password. Leave blank if using username/password.",
      "sensitive": true,
      "required": false,
      "default": ""
    },
    "${CFG_PREFIX}user": {
      "type": "string",
      "title": "Username",
      "description": "${BRAND_NAME} username. Used with Password if no Service Account Token is set.",
      "required": false,
      "default": ""
    },
    "${CFG_PREFIX}password": {
      "type": "string",
      "title": "Password",
      "description": "${BRAND_NAME} password. Used with Username if no Service Account Token is set.",
      "sensitive": true,
      "required": false,
      "default": ""
    }
  },
  "compatibility": {
    "platforms": ["darwin", "win32", "linux"],
    "runtimes": { "python": ">=3.13" }
  }
}
