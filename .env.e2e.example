# Copy to .env.e2e and fill in. .env.e2e is gitignored.
#
# Required:
HYDROLIX_USER=
HYDROLIX_PASSWORD=

# Optional. If unset, derived from CR spec.hydrolix_url.
# HYDROLIX_HOST=qe-innovations-2.hydrolix.dev

# Image conventions
# -----------------
# When MCP_HYDROLIX_E2E_IMAGE is unset, the suite defaults to ttl.sh and the
# tag becomes "10m" (ttl.sh interprets the tag as a TTL spec). Identity goes
# in the image name: ttl.sh/mcp-hydrolix-e2e-{user}-{branch}-{shortsha}[-dirty]-{epoch}
#
# When MCP_HYDROLIX_E2E_IMAGE is a non-ttl.sh path, identity goes in the tag
# (mirroring publish-feature.yml): branch-{branch}-{shortsha}[-dirty]
#
# MCP_HYDROLIX_E2E_IMAGE=us-docker.pkg.dev/hdx-art/t/mcp-hydrolix
# MCP_HYDROLIX_E2E_IMAGE_TAG=branch-il-test-end-to-end-harness-a233b60

# Set to 1 when you've already published the image (e.g. via
# `gh workflow run publish-feature.yml`) and only want the suite to patch the
# CR and run the tests.
# MCP_HYDROLIX_E2E_SKIP_BUILD=0

# Kubernetes addressing. All optional; defaults are inferred from your
# current kubectl context. Set explicitly to pin to a specific cluster.
# MCP_HYDROLIX_E2E_KUBECONFIG=/home/you/.kube/config
# MCP_HYDROLIX_E2E_KUBE_CONTEXT=qe-innovations-2
# MCP_HYDROLIX_E2E_NAMESPACE=qe-innovations-2

# Hydrolix CR (kind: hydrolixclusters.hydrolix.io/v1) name in the namespace.
# Auto-discovered when exactly one CR exists. Set explicitly to disambiguate.
# MCP_HYDROLIX_E2E_CLUSTER_NAME=hdx

# Operator-managed Deployment name. Override only if your cluster renames it.
# MCP_HYDROLIX_E2E_DEPLOYMENT_NAME=mcp-hydrolix

# Seconds to wait for the Deployment rollout after patching the CR.
# MCP_HYDROLIX_E2E_READY_TIMEOUT=180

# Path to this env file. The suite reads it via dotenv at session start.
# MCP_HYDROLIX_E2E_ENV_FILE=.env.e2e
