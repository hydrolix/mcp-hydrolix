{
  "permissions": {
    "deny": [
      "Bash(gh pr create *--repo ClickHouse/mcp-clickhouse*)",
      "Bash(gh pr create *--repo=ClickHouse/mcp-clickhouse*)",
      "Bash(gh pr create *-R ClickHouse/mcp-clickhouse*)",
      "Bash(gh pr create *-R=ClickHouse/mcp-clickhouse*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/block-clickhouse-pr.py\""
          }
        ]
      },
      {
        "matcher": "mcp__.*create_pull_request",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/block-clickhouse-pr.py\""
          }
        ]
      }
    ]
  }
}
